# Database (docker-compose defaults)
DATABASE_URL=postgresql+psycopg://ibbot:ibbot@db:5432/ibbot
REDIS_URL=redis://redis:6379/0

# External APIs
QUIVER_API_KEY=your_quiver_api_key_here

# Interactive Brokers
IB_HOST=host.docker.internal
IB_PORT=4001
IB_CLIENT_ID=1
IB_EXTRA_ACCOUNTS=

# Trading configuration
ENABLE_LIVE_TRADING=false
PRICE_SOURCE=auto
MARKET_CALENDAR=XNYS
TRADING_HALT=false
LIVE_MAX_EXEC_PER_HOUR=20
LIVE_MAX_ORDERS_PER_HOUR=200
LIVE_MAX_CONSECUTIVE_ERRORS=3
LIVE_MAX_PRICE_AGE_SECONDS=900
LIVE_MAX_PRICE_DEVIATION=0.2
LIVE_MAX_SPREAD_PCT=0.05
LIVE_MAX_ABS_PRICE=100000

# Shadow preview (optional)
SHADOW_PREVIEW_ACCOUNTS=
SHADOW_PREVIEW_PORTFOLIOS=
SHADOW_PREVIEW_ALLOCATION=10000

# Optional paths
PLOT_DATA_PATH=/app/.cache/plot_data.json
VALIDATION_RESULTS_PATH=/app/.cache/last_validation_results.json
PLOT_DATA_SOURCE=unknown
